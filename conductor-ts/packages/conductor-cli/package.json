{
  "name": "@conductor/cli",
  "version": "0.1.0",
  "description": "CLI for Conductor multi-agent workflow orchestration",
  "type": "module",
  "bin": {
    "conductor": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "start": "node --enable-source-maps dist/index.js"
  },
  "dependencies": {
    "@conductor/core": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^10.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "vitest": "^2.0.0"
  }
}
