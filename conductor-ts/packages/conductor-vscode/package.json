{
  "name": "conductor-vscode",
  "version": "0.1.0",
  "displayName": "Conductor",
  "description": "Run multi-agent Conductor workflows in VS Code Copilot Chat",
  "publisher": "conductor",
  "repository": {
    "type": "git",
    "url": "https://github.com/fenghaitao/conductor"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": ["AI", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:@github/copilot-sdk --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:@github/copilot-sdk --format=cjs --platform=node --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "pnpm build && vsce package"
  },
  "contributes": {
    "chatParticipants": [
      {
        "id": "conductor.conductor",
        "name": "conductor",
        "fullName": "Conductor",
        "description": "Run multi-agent Conductor workflows",
        "isSticky": false
      }
    ],
    "commands": [
      {
        "command": "conductor.runWorkflow",
        "title": "Conductor: Run Workflow"
      }
    ],
    "languageModelTools": [
      {
        "name": "conductor_runWorkflow",
        "displayName": "Run Conductor Workflow",
        "toolReferenceName": "conductorRun",
        "canBeReferencedInPrompt": true,
        "userDescription": "Run a Conductor multi-agent workflow from a YAML file.",
        "modelDescription": "Runs a multi-agent Conductor YAML workflow and returns its output. Use when the user wants to execute a Conductor workflow file.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "workflowPath": {
              "type": "string",
              "description": "Relative or absolute path to the workflow YAML file"
            },
            "inputs": {
              "type": "object",
              "description": "Key-value pairs of workflow inputs (all values must be strings)",
              "additionalProperties": { "type": "string" }
            }
          },
          "required": ["workflowPath"]
        }
      }
    ]
  },
  "dependencies": {
    "@conductor/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "@vscode/vsce": "^3.0.0"
  }
}
